	"format-disconnected": "ŌÜĀ ",
	"format-alt": "{ipaddr}"
	},

"temperature": {
	"thermal-zone": 2,
	"critical-threshold": 80,
	"format-critical": " {icon}{temperatureC}┬░C",
	"format": " {temperatureC}┬░C ",
	"format-icons": ["’Ø½", "’ŗē", "’Ø®"]
  },
