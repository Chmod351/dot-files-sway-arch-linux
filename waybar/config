"clock#3": {
    "format": "{:%H:%M}",
    "timezone": "America/Argentina/Buenos_Aires",
    "tooltip": true,
    // El 'tooltip-format' define la estructura general
    "tooltip-format": "<tt><big>{calendar}</big></tt>",
