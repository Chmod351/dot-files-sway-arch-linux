{
	"layer": "top",
	"height":0,
	"position": "top",
	"modules-left": [
	  "tray",
		"custom/clipboard",
		"sway/workspaces",
		"keyboard-state",
	],
	"modules-center": [
		"clock#3",
		"custom/weather",
	],
	"modules-right": [
		"pulseaudio",
		"disk",
		"cpu",
		"temperature",
		"memory",
