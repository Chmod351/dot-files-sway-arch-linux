{
	"layer": "top",
	"height":0,
	"position": "top",
	"modules-left": [
	  "tray",
		"custom/clipboard",
		"sway/workspaces",
		"keyboard-state",
	],
	"modules-center": [
		"clock#3",
		"custom/weather",
	],
	"modules-right": [
		"pulseaudio",
		"custom/diskcapacity",
    "custom/telemetria",
		"memory",
		"network",
	],
 "custom/clipboard": {
	"format": "{} яЛТ  ",
	"tooltip":true,
	"on-click": "cliphist list | wofi -d -p | cliphist decode | wl-copy",
	"on-click-right": "cliphist wipe",
	"interval": 5
	},
"sway/workspaces": {
	"disable-scroll": true,
	"format": "{icon}",
	"format-icons": {
	   "2": "юЭЕ  2",
	   "1": "яДб  1",
	   "3": "яВ▒  3",
     	 "4":"юЩН  4",
	"urgent": "яБк  atention!",
	       }
	},	
"tray": {
	"icon-size": 15
 	},
"clock#3": {
    "format": "{:%H:%M}",
    "timezone": "America/Argentina/Buenos_Aires",
    "tooltip": true,
    // El 'tooltip-format' define la estructura general
    "tooltip-format": "<tt><big>{calendar}</big></tt>",
    "calendar": {
        "mode": "month",
        "on-scroll": 1,
        "format": {
            "months":     "<span color='#7dcfff'><b>{}</b></span>",
            "days":       "<span color='#a9b1d6'>{}</span>",
            "weekdays":   "<span color='#ff9e64'><b>{}</b></span>",
            "today":      "<span color='#0db9d7'><b><u>{}</u></b></span>" // <-- ESTO RESALTA EL D├НA ACTUAL
        }
    }
},
"custom/weather": {
   "format": "{}┬░",
    "exec": "wttrbar",
    "return-type": "json",
    "interval": 10000,
    "tooltip": true
},
"pulseaudio": {
	"format": "{icon}  {volume:2}% {format_source} ",
	"format-bluetooth": "{icon}  {volume}%яКФ",
	"format-muted": "MUTE",
	"format-source": "яД░ {volume}%",
	"format-source-muted": "яД▒",
	"format-icons": {
		"headphones": "яАе",
		"default": [
				"яАз",
				"яАи"
			]
		},
	"scroll-step": 5,
   "on-click":"pamixer -t",
   "on-click-right":"pavucontrol"
	},
"memory": {
	  "interval": 5,
	  "format": "ю┐Е  {}%"
	},
  "network": {
	"format-wifi": "({signalStrength}%) яЗл  ",
	"format-ethernet": " ґ░ИБ ",
	"tooltip-format": "{gwaddr}",
	"format-linked": "{ifname} (No IP) яЮЦ",
	"format-disconnected": "тЪа ",
	"format-alt": "{ipaddr}"
	},
	"disk": {
		"interval": 5,
    "tooltip":true,
		"format": "яГЗ {percentage_used:2}% ",
		"path": "/"
	},
"keyboard-state": {
	"numlock": true,
	"capslock": true,
	"format": "{icon}",
	"format-icons": {
		"locked": "яАг  ",
		"unlocked": ""
	}
 },
"custom/telemetria": {
    "exec": "~/.dotfiles/bashscripts/telemetria.sh",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "tooltip": true
},
"custom/diskcapacity": {
    "exec": "~/.dotfiles/bashscripts/diskcapacity.sh",
    "return-type": "json",
    "interval": 60, // El espacio en disco no cambia cada 2 segundos, con 1 min sobra.
    "format": "{}",
    "tooltip": true,
    "on-click": "alacritty -e df -h"
},
}
