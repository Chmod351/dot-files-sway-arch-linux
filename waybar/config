"clock#3": {
    "format": "{:%H:%M}",
    "timezone": "America/Argentina/Buenos_Aires",
    "tooltip": true,
    // El 'tooltip-format' define la estructura general
    "tooltip-format": "<tt><big>{calendar}</big></tt>",
    "calendar": {
        "mode": "month",
        "on-scroll": 1,
        "format": {
            "months":     "<span color='#7dcfff'><b>{}</b></span>",
            "days":       "<span color='#a9b1d6'>{}</span>",
            "weekdays":   "<span color='#ff9e64'><b>{}</b></span>",
            "today":      "<span color='#0db9d7'><b><u>{}</u></b></span>" // <-- ESTO RESALTA EL D├ŹA ACTUAL
        }
    }
},
"custom/weather": {
   "format": "{}┬░",
    "exec": "wttrbar",
    "return-type": "json",
    "interval": 10000,
    "tooltip": true
},
"pulseaudio": {
	"format": "{icon}  {volume:2}% {format_source} ",
