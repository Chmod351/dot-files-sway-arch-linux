{
	"layer": "top",
	"height":0,
	"position": "top",
	"modules-left": [
	  "tray",
		"custom/clipboard",
		"sway/workspaces",
		"keyboard-state",
	],
	"modules-center": [
		"clock#3",
		"custom/weather",
	],
	"modules-right": [
		"pulseaudio",
		"disk",
		"cpu",
		"temperature",
		"memory",
		"custom/vram",
    "temperature#gpu",
		"network",
	],
 "custom/clipboard": {
	"format": "{} ’ŗÆ  ",
	"tooltip":true,
	"on-click": "cliphist list | wofi -d -p | cliphist decode | wl-copy",
	"on-click-right": "cliphist wipe",
	"interval": 5
	},
"sway/workspaces": {
	"disable-scroll": true,
	"format": "{icon}",
	"format-icons": {
	   "2": "ŅØģ  2",
